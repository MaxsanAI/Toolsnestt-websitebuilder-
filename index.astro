---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Tools Nestt SaaS Engine",
  "operatingSystem": "Web",
  "applicationCategory": "DeveloperApplication",
  "areaServed": {
    "@type": "Country",
    "name": "United States"
  },
  "offers": {
    "@type": "Offer",
    "price": "9.00",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  }
};
---

<Layout title="Tools Nestt | Hybrid Website Hosting & SaaS Engine | US West Edge">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <main class="bg-[#0f172a]">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center px-6 pt-20 overflow-hidden">
      <!-- Glow Effect -->
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-indigo-600/10 blur-[120px] rounded-full"></div>
      
      <div class="max-w-5xl mx-auto text-center relative z-10">
        <!-- Infrastructure Badge -->
        <div class="mb-6 inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-emerald-400 text-[10px] font-black uppercase tracking-[0.2em]">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Primary Node: North America West (SFO/PDX)
        </div>

        <h1 class="text-5xl md:text-8xl font-black tracking-tighter mb-6 bg-gradient-to-b from-white to-slate-500 bg-clip-text text-transparent italic">
          CODE TO LIVE. <br/> IN SECONDS.
        </h1>
        
        <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10">
          The engine behind <span class="text-indigo-400 italic">maximhot.workers.dev</span>. Optimized for <span class="text-white border-b border-indigo-500">Silicon Valley Edge nodes</span>. Deploy folders to R2 or paste code to D1. 
          <span class="block mt-4 font-bold text-white tracking-tight">7-Day Free Trial. No credit card required.</span>
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="/dashboard" class="px-10 py-4 bg-indigo-600 rounded-full font-black uppercase tracking-widest hover:scale-105 transition-all shadow-[0_0_30px_rgba(79,70,229,0.4)]">Get Started</a>
          <a href="/pricing" class="px-10 py-4 bg-slate-800 rounded-full font-black uppercase tracking-widest border border-slate-700 hover:bg-slate-700 transition-all">View Plans</a>
        </div>

        <!-- Latency Hint -->
        <p class="mt-8 text-slate-600 text-[11px] uppercase tracking-widest font-medium">
          Global Edge Network • <span class="text-indigo-400/60">Sub-10ms Latency in Western US</span>
        </p>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-32 max-w-4xl mx-auto px-6 border-t border-slate-900">
      <h2 class="text-3xl font-black mb-16 text-center text-white tracking-tighter uppercase italic">Engineering FAQ</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-8 rounded-3xl bg-slate-900/30 border border-slate-800/50 hover:border-indigo-500/30 transition-colors">
          <h3 class="font-bold text-white mb-3">Where is my site hosted?</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Your content is distributed globally via Cloudflare's network, with primary storage nodes located in **Western North America** for maximum performance and data integrity.</p>
        </div>
        <div class="p-8 rounded-3xl bg-slate-900/30 border border-slate-800/50 hover:border-indigo-500/30 transition-colors">
          <h3 class="font-bold text-white mb-3">Trial & Billing</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Start with a 7-day unrestricted trial. We use **Paddle** as our global reseller to ensure secure, compliant transactions in USD worldwide.</p>
        </div>
        <div class="p-8 rounded-3xl bg-slate-900/30 border border-slate-800/50 hover:border-indigo-500/30 transition-colors">
          <h3 class="font-bold text-white mb-3">Custom Domains & SSL</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Every project supports custom CNAME mapping with automated SSL termination at the edge. No manual certificate management required.</p>
        </div>
        <div class="p-8 rounded-3xl bg-slate-900/30 border border-slate-800/50 hover:border-indigo-500/30 transition-colors">
          <h3 class="font-bold text-white mb-3">Hybrid Deployment</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Choose between full folder uploads to **R2 Storage** or high-speed SQL-backed hosting via **Cloudflare D1** for code snippets.</p>
        </div>
      </div>
    </section>

    <!-- Footer / Legal Info for Paddle -->
    <footer class="py-12 border-t border-slate-900 text-center px-6">
      <p class="text-slate-500 text-xs tracking-widest uppercase">
        Infrastructure: Cloudflare Edge (US-West) • Payments: Paddle MoR
      </p>
    </footer>
  </main>
</Layout>
