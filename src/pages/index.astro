---
import Layout from '../layouts/Layout.astro';

// Podaci za specifični SaaS Markup na naslovnoj
const pageTitle = "Tools Nestt | World's Fastest Edge Deployment Engine";
const pageDescription = "High-performance hybrid hosting. Deploy entire folders to R2 or paste code to D1. 7-day free trial on Cloudflare US-West infrastructure.";
const pageURL = "https://websitebuilder.toolsnestt.com";

const saasMarkup = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Tools Nestt",
  "url": pageURL,
  "description": pageDescription,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web, Windows, macOS, Linux",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "USD",
    "lowPrice": "9",
    "highPrice": "69.00",
    "offerCount": "3"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "124"
  },
  "screenshot": "https://websitebuilder.toolsnestt.com/dashboard-preview.png",
  "softwareVersion": "2.0.1",
  "author": {
    "@type": "Person",
    "name": "Vladimir Maksimovic",
    "alternateName": "Maxsan"
  }
};
---

<Layout title={pageTitle} description={pageDescription}>
  
  <!-- UBRIZGAVANJE MARKUP-A DIREKTNO U INDEX -->
  <script type="application/ld+json" set:html={JSON.stringify(saasMarkup)} />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-indigo-600/10 blur-[120px] rounded-full -z-10"></div>

    <div class="max-w-7xl mx-auto px-6 text-center">
      <!-- Status Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-[10px] font-black uppercase tracking-widest mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
        </span>
        US-West Edge Infrastructure Active
      </div>

      <h1 class="text-7xl md:text-8xl font-black text-white italic tracking-tighter uppercase leading-[0.9] mb-8">
        Push to the <br /> <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-white">Edge in Seconds.</span>
      </h1>

      <p class="max-w-2xl mx-auto text-slate-400 text-lg md:text-xl mb-12 italic leading-relaxed">
        {pageDescription}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/register" class="px-10 py-5 bg-white text-black font-black uppercase text-xs tracking-widest rounded-2xl hover:bg-indigo-500 hover:text-white transition-all shadow-2xl shadow-white/5 active:scale-95">
          Start 7-Day Free Trial
        </a>
        <a href="/pricing" class="px-10 py-5 bg-slate-900 text-white font-black uppercase text-xs tracking-widest rounded-2xl border border-slate-800 hover:bg-slate-800 transition-all">
          View Plans
        </a>
      </div>

      <!-- Preview ekrana -->
      <div class="mt-24 relative max-w-5xl mx-auto">
        <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-slate-800 rounded-[2.5rem] blur opacity-20"></div>
        <div class="relative bg-[#020617] border border-slate-800 rounded-[2rem] p-4 shadow-2xl">
          <div class="flex items-center gap-2 mb-4 px-4">
            <div class="w-3 h-3 rounded-full bg-red-500/20"></div>
            <div class="w-3 h-3 rounded-full bg-amber-500/20"></div>
            <div class="w-3 h-3 rounded-full bg-emerald-500/20"></div>
          </div>
          <div class="aspect-video bg-slate-950 rounded-xl overflow-hidden flex items-center justify-center border border-slate-900">
             <span class="text-slate-800 font-black text-5xl italic tracking-tighter uppercase opacity-20 italic">Tools Nestt v2.0</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Specifikacije (SaaS Content) -->
  <section class="py-32 px-6 bg-[#020617]">
    <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-12">
      <div class="p-10 rounded-[3rem] border border-slate-900 bg-slate-950/20">
        <div class="text-2xl mb-4">💎</div>
        <h3 class="text-white font-black italic uppercase mb-2">Code to D1</h3>
        <p class="text-slate-500 text-sm italic leading-relaxed">Direct SQL injection for your HTML components. No latency, just raw edge speed.</p>
      </div>
      <div class="p-10 rounded-[3rem] border border-slate-900 bg-slate-950/20">
        <div class="text-2xl mb-4">📦</div>
        <h3 class="text-white font-black italic uppercase mb-2">Folder to R2</h3>
        <p class="text-slate-500 text-sm italic leading-relaxed">Sync entire directories with a single drag. Global asset delivery via Cloudflare CDN.</p>
      </div>
      <div class="p-10 rounded-[3rem] border border-slate-900 bg-slate-950/20">
        <div class="text-2xl mb-4">🛡️</div>
        <h3 class="text-white font-black italic uppercase mb-2">Edge Security</h3>
        <p class="text-slate-500 text-sm italic leading-relaxed">Advanced WAF protection and auto-firewall rules for every hosted project.</p>
      </div>
    </div>
  </section>
</Layout>
