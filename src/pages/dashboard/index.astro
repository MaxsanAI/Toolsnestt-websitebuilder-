---
import Layout from '../layouts/Layout.astro';

// 1. ZAKLJUČAVANJE: Provera sesije
const session = Astro.cookies.get('session');
if (!session) {
  return Astro.redirect('/login');
}

// 2. PRAVI FETCH: Uzimanje podataka iz D1 baze
const { DB } = Astro.locals.runtime.env;

// Uzimamo projekte samo za ulogovanog korisnika (pretpostavljamo da session.value čuva email ili ID)
// Za sada vučemo sve, dok ne podesimo punu filtraciju po korisniku
let projects = [];
try {
  const result = await DB.prepare("SELECT * FROM projects ORDER BY created_at DESC").all();
  projects = result.results;
} catch (e) {
  console.error("D1 Fetch Error:", e);
  // Ako baza još nije spremna, ostavljamo praznu listu ili tvoje mock podatke
}

// Izračunavanje trial dana (primer)
const trialDays = 4;
---

<Layout title="Dashboard | Tools Nestt">
  <div class="flex min-h-screen bg-[#0b1120] text-slate-200">
    
    <aside class="w-64 border-r border-slate-800/50 p-6 flex flex-col fixed h-full bg-[#0b1120]">
      <div class="mb-10">
        <h2 class="text-white font-black italic tracking-tighter text-xl leading-none">TOOLS NESTT</h2>
        <p class="text-[10px] text-indigo-500 font-bold uppercase tracking-[0.2em] mt-1">SaaS Engine v2</p>
      </div>
      
      <nav class="space-y-2 flex-1">
        <a href="/dashboard" class="block px-4 py-2 rounded-xl bg-indigo-600/10 text-indigo-400 font-bold text-sm border border-indigo-500/20">Projects</a>
        <a href="/pricing" class="block px-4 py-2 rounded-xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition text-sm">Subscription</a>
        <a href="/legal/terms" class="block px-4 py-2 rounded-xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition text-sm">Legal & Docs</a>
      </nav>

      <div class="bg-indigo-500/5 border border-indigo-500/10 p-5 rounded-[2rem]">
        <div class="flex justify-between items-end mb-2">
           <p class="text-[10px] text-indigo-400 font-black uppercase tracking-widest">Trial</p>
           <p class="text-xs text-white font-bold">{trialDays}/7 Days</p>
        </div>
        <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
          <div class="bg-indigo-500 h-full shadow-[0_0_10px_#6366f1]" style={`width: ${(trialDays/7)*100}%`}></div>
        </div>
      </div>
    </aside>

    <main class="flex-1 ml-64 p-12 bg-[#0b1120]">
      <div class="flex justify-between items-center mb-16">
        <div>
          <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter leading-none">My Projects</h1>
          <p class="text-slate-500 text-sm italic mt-2">Active deployments on <span class="text-indigo-400">maximhot.workers.dev</span></p>
        </div>
        <button id="openModal" class="px-8 py-4 bg-white text-black font-black uppercase text-[10px] tracking-widest rounded-2xl hover:bg-indigo-400 hover:text-white transition-all shadow-2xl shadow-white/5 active:scale-95">
          + New Deployment
        </button>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.length === 0 ? (
          <div class="col-span-full py-20 text-center border-2 border-dashed border-slate-800 rounded-[3rem]">
            <p class="text-slate-500 italic">No projects found. Deploy your first idea!</p>
          </div>
        ) : (
          projects.map(p => (
            <div class="p-8 rounded-[2.5rem] bg-slate-900/40 border border-slate-800/50 hover:border-indigo-500/30 transition-all group relative overflow-hidden backdrop-blur-sm">
              <div class="flex justify-between items-start mb-6">
                <div class="w-12 h-12 rounded-2xl bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center text-xl shadow-inner">
                  {p.type === 'code' ? '⚡' : '📂'}
                </div>
                <span class={`text-[10px] font-black uppercase px-3 py-1 rounded-full border ${p.status === 'active' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 'bg-amber-500/10 text-amber-400 border-amber-500/20'}`}>
                  {p.status}
                </span>
              </div>
              
              <h3 class="text-white font-bold text-xl mb-1 tracking-tight group-hover:text-indigo-400 transition-colors">{p.name}</h3>
              <p class="text-slate-500 text-xs mb-8 font-mono opacity-60">https://{p.name}.maximhot.workers.dev</p>
              
              <div class="flex gap-3">
                <a href={`/dashboard/edit/${p.id}`} class="flex-1 text-center py-3 bg-slate-800/50 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-700 transition-colors border border-white/5">Manage</a>
                <a href={`https://${p.name}.maximhot.workers.dev`} target="_blank" class="px-4 py-3 bg-indigo-600 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-indigo-500 transition-all">Live</a>
              </div>
            </div>
          ))
        )}
      </div>
    </main>

    <div id="projectModal" class="fixed inset-0 bg-[#0b1120]/90 backdrop-blur-sm z-50 hidden flex items-center justify-center p-6">
      </div>
  </div>
</Layout>
