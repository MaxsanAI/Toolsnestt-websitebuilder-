---
import Layout from '../../layouts/Layout.astro';

// Ovde ćemo kasnije zameniti sa pravim FETCH-om iz D1 baze
const projects = [
  { id: '1', name: 'my-portfolio', type: 'code', status: 'active' },
  { id: '2', name: 'alpha-test', type: 'folder', status: 'trial' }
];

const trialDays = 4;
---

<Layout title="Dashboard | Tools Nestt">
  <div class="flex min-h-screen bg-[#020617] text-slate-200">
    <!-- Sidebar -->
    <aside class="w-64 border-r border-slate-800/50 p-6 flex flex-col fixed h-full">
      <div class="mb-10">
        <h2 class="text-white font-black italic tracking-tighter text-xl leading-none">TOOLS NESTT</h2>
        <p class="text-[10px] text-indigo-500 font-bold uppercase tracking-[0.2em] mt-1">SaaS Engine v2</p>
      </div>
      
      <nav class="space-y-2 flex-1">
        <a href="/dashboard" class="block px-4 py-2 rounded-xl bg-indigo-600/10 text-indigo-400 font-bold text-sm border border-indigo-500/20">Projects</a>
        <a href="/pricing" class="block px-4 py-2 rounded-xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition text-sm">Subscription</a>
        <a href="/legal/terms" class="block px-4 py-2 rounded-xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition text-sm">Legal & Docs</a>
      </nav>

      <div class="bg-indigo-500/5 border border-indigo-500/10 p-5 rounded-[2rem]">
        <div class="flex justify-between items-end mb-2">
           <p class="text-[10px] text-indigo-400 font-black uppercase tracking-widest">Trial</p>
           <p class="text-xs text-white font-bold">{trialDays}/7 Days</p>
        </div>
        <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
          <div class="bg-indigo-500 h-full shadow-[0_0_10px_#6366f1]" style={`width: ${(trialDays/7)*100}%`}></div>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-12">
      <div class="flex justify-between items-center mb-16">
        <div>
          <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter leading-none">My Projects</h1>
          <p class="text-slate-500 text-sm italic mt-2">Active deployments on <span class="text-indigo-400">maximhot.workers.dev</span></p>
        </div>
        <button id="openModal" class="px-8 py-4 bg-white text-black font-black uppercase text-[10px] tracking-widest rounded-2xl hover:bg-indigo-400 hover:text-white transition-all shadow-2xl shadow-white/5 active:scale-95">
          + New Deployment
        </button>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map(p => (
          <div class="p-8 rounded-[2.5rem] bg-slate-900/40 border border-slate-800/50 hover:border-indigo-500/30 transition-all group relative overflow-hidden">
            <div class="flex justify-between items-start mb-6">
              <div class="w-12 h-12 rounded-2xl bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center text-xl shadow-inner">
                {p.type === 'code' ? '⚡' : '📂'}
              </div>
              <span class={`text-[10px] font-black uppercase px-3 py-1 rounded-full border ${p.status === 'active' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 'bg-amber-500/10 text-amber-400 border-amber-500/20'}`}>
                {p.status}
              </span>
            </div>
            
            <h3 class="text-white font-bold text-xl mb-1 tracking-tight group-hover:text-indigo-400 transition-colors">{p.name}</h3>
            <p class="text-slate-500 text-xs mb-8 font-mono opacity-60">https://{p.name}.maximhot.workers.dev</p>
            
            <div class="flex gap-3">
              <a href={`/dashboard/edit/${p.id}`} class="flex-1 text-center py-3 bg-slate-800/50 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-700 transition-colors border border-white/5">Manage</a>
              <a href={`https://${p.name}.maximhot.workers.dev`} target="_blank" class="px-4 py-3 bg-indigo-600 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-indigo-500 transition-all">Live</a>
            </div>
          </div>
        ))}
      </div>
    </main>

    <!-- Modal za Novi Projekat -->
    <div id="projectModal" class="fixed inset-0 bg-[#020617]/90 backdrop-blur-sm z-50 hidden flex items-center justify-center p-6">
      <div class="bg-slate-900 border border-slate-800 p-10 rounded-[3rem] w-full max-w-md shadow-2xl">
        <h2 class="text-2xl font-black text-white italic uppercase mb-2">Create Project</h2>
        <p class="text-slate-400 text-sm mb-8 italic">Choose a unique name for your URL.</p>
        
        <div class="space-y-6">
          <div>
            <label class="text-[10px] font-black uppercase text-indigo-400 mb-2 block tracking-widest">Project Name</label>
            <input type="text" id="projName" placeholder="my-awesome-site" class="w-full bg-black/50 border border-slate-800 rounded-xl px-4 py-3 text-white focus:border-indigo-500 outline-none transition-all font-mono" />
          </div>
          
          <div class="flex gap-4">
            <button id="closeModal" class="flex-1 py-4 bg-slate-800 rounded-xl font-bold text-xs uppercase tracking-widest">Cancel</button>
            <button id="createBtn" class="flex-1 py-4 bg-indigo-600 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-indigo-500 shadow-lg shadow-indigo-600/20">Create</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const modal = document.getElementById('projectModal');
    const openBtn = document.getElementById('openModal');
    const closeBtn = document.getElementById('closeModal');
    const createBtn = document.getElementById('createBtn');

    openBtn.onclick = () => modal.classList.remove('hidden');
    closeBtn.onclick = () => modal.classList.add('hidden');
    
    // Zatvori na klik van modala
    window.onclick = (event) => {
      if (event.target == modal) modal.classList.add('hidden');
    }

    createBtn.onclick = async () => {
      const name = document.getElementById('projName').value;
      if (!name) return alert('Enter a project name!');
      
      // Ovde ide tvoj API poziv ka D1 da kreiraš projekat
      // console.log("Creating project in D1:", name);
      
      // Simulacija: Redirect na edit stranicu nakon kreiranja
      window.location.href = `/dashboard/edit/new?name=${name}`;
    }
  </script>
</Layout>
