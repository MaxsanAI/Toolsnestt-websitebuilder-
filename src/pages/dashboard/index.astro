---
import Layout from '../../layouts/Layout.astro';

// --- 1. ZAKLJUČAVANJE (AUTH CHECK) ---
const session = Astro.cookies.get('session');
if (!session || !session.value) {
  return Astro.redirect('/login');
}

const userEmail = session.value; // Pretpostavljamo da sesija čuva email korisnika

// --- 2. LOGOUT LOGIKA ---
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action");

  if (action === "logout") {
    Astro.cookies.delete('session', { path: '/' });
    return Astro.redirect('/login');
  }

  // Logika za brisanje projekta (da ne bude samo prazan dashboard)
  if (action === "delete_project") {
    const projectId = formData.get("projectId");
    const { DB } = Astro.locals.runtime.env;
    await DB.prepare("DELETE FROM projects WHERE id = ? AND user_email = ?").bind(projectId, userEmail).run();
    return Astro.redirect('/dashboard');
  }
}

// --- 3. FETCH PODATAKA IZ D1 ---
let projects = [];
const runtime = Astro.locals.runtime;

if (runtime?.env?.DB) {
  try {
    const { results } = await runtime.env.DB.prepare(
      "SELECT * FROM projects WHERE user_email = ? ORDER BY created_at DESC"
    ).bind(userEmail).all();
    projects = results;
  } catch (e) {
    console.error("D1 Database Error:", e);
  }
}
---

<Layout title="User Dashboard | Tools Nestt">
  <div class="flex min-h-screen bg-[#0b1120] text-slate-200 font-sans">
    
    <!-- Sidebar -->
    <aside class="w-72 border-r border-slate-800/40 p-8 flex flex-col fixed h-full bg-[#0b1120] z-20">
      <div class="mb-12">
        <a href="/" class="text-white font-black italic tracking-tighter text-2xl leading-none block">
          TOOLS NESTT
        </a>
        <div class="flex items-center gap-2 mt-2">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest leading-none">System Online</p>
        </div>
      </div>
      
      <nav class="space-y-1.5 flex-1">
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-2xl bg-indigo-500/10 text-indigo-400 font-bold text-sm border border-indigo-500/20 shadow-lg shadow-indigo-500/5">
          <span>⚡</span> Projects
        </a>
        <a href="/dashboard/billing" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition-all text-sm border border-transparent hover:border-slate-700">
          <span>💳</span> Subscription
        </a>
        <a href="/legal/terms" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition-all text-sm">
          <span>⚖️</span> Legal & API Docs
        </a>
      </nav>

      <!-- User & Logout -->
      <div class="pt-6 border-t border-slate-800/50">
        <p class="text-[10px] text-slate-500 uppercase font-black mb-3 px-2 tracking-widest">Account</p>
        <div class="px-4 py-3 bg-slate-900/50 rounded-2xl border border-slate-800 mb-4 overflow-hidden">
          <p class="text-xs font-bold text-white truncate">{userEmail}</p>
        </div>
        <form method="POST">
          <button name="action" value="logout" class="w-full px-4 py-3 text-left text-xs font-black uppercase tracking-widest text-red-400 hover:bg-red-500/10 rounded-xl transition-colors">
            Log Out →
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-72 p-16">
      <div class="max-w-6xl mx-auto">
        
        <!-- Header Section -->
        <div class="flex justify-between items-end mb-16">
          <div>
            <h1 class="text-5xl font-black text-white italic uppercase tracking-tighter leading-none mb-4">
              Console <span class="text-indigo-500">_</span>
            </h1>
            <p class="text-slate-400 text-sm font-medium">
              Manage your deployments on <span class="text-indigo-400 border-b border-indigo-500/30">maximhot.workers.dev</span>
            </p>
          </div>
          
          <button class="px-8 py-4 bg-indigo-600 text-white font-black uppercase text-[10px] tracking-[0.2em] rounded-2xl hover:bg-indigo-500 hover:-translate-y-1 transition-all shadow-xl shadow-indigo-600/20 active:scale-95">
            + New Deployment
          </button>
        </div>

        <!-- Projects Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.length === 0 ? (
            <div class="col-span-full py-32 text-center border-2 border-dashed border-slate-800/50 rounded-[3rem] bg-slate-900/20">
              <div class="text-4xl mb-4">📂</div>
              <h2 class="text-xl font-bold text-white mb-2 tracking-tight">Your nest is empty</h2>
              <p class="text-slate-500 text-sm max-w-xs mx-auto">Deploy your first app or website to see it appear here in the dashboard.</p>
            </div>
          ) : (
            projects.map(p => (
              <div class="group p-8 rounded-[2.5rem] bg-slate-900/40 border border-slate-800/50 hover:border-indigo-500/30 transition-all relative overflow-hidden backdrop-blur-xl">
                <div class="absolute top-0 right-0 p-4 opacity-0 group-hover:opacity-100 transition-opacity">
                  <form method="POST">
                    <input type="hidden" name="projectId" value={p.id} />
                    <button name="action" value="delete_project" class="text-slate-500 hover:text-red-400 p-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </form>
                </div>

                <div class="w-14 h-14 rounded-2xl bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center text-2xl mb-8 shadow-inner">
                   {p.type === 'code' ? '⚡' : '🚀'}
                </div>
                
                <h3 class="text-white font-black text-xl mb-1 tracking-tight">{p.name}</h3>
                <p class="text-slate-500 text-[10px] mb-8 font-mono uppercase tracking-widest">{p.url || `https://${p.name}.maximhot.workers.dev`}</p>
                
                <div class="flex gap-2">
                  <a href={`/dashboard/manage/${p.id}`} class="flex-1 text-center py-3.5 bg-slate-800 hover:bg-slate-700 rounded-xl text-[9px] font-black uppercase tracking-[0.2em] transition-colors border border-white/5">
                    Settings
                  </a>
                  <a href={p.url} target="_blank" class="px-5 py-3.5 bg-indigo-600 hover:bg-indigo-500 rounded-xl text-[9px] font-black uppercase tracking-[0.2em] transition-all shadow-lg shadow-indigo-600/20">
                    Live
                  </a>
                </div>
              </div>
            ))
          )}
        </div>
      </div>
    </main>
  </div>
</Layout>
