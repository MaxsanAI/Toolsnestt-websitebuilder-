---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login | Tools Nestt">
  <main class="min-h-screen flex items-center justify-center px-6 py-20">
    <div class="w-full max-w-md bg-slate-900/50 border border-slate-800 p-10 rounded-[2.5rem] shadow-2xl backdrop-blur-md">
      <div class="text-center mb-10">
        <h1 class="text-3xl font-black text-white italic tracking-tighter uppercase mb-2">Magic Access</h1>
        <p class="text-slate-500 text-xs italic">No passwords. Just your email.</p>
      </div>

      <div class="space-y-6">
        <div>
          <label class="text-[10px] font-black uppercase text-indigo-400 mb-2 block tracking-widest">Email Address</label>
          <!-- Dodao sam name="email" i autocomplete radi boljeg UX-a -->
          <input 
            id="email" 
            name="email" 
            type="email" 
            autocomplete="email"
            placeholder="name@company.com" 
            class="w-full bg-black/40 border border-slate-800 rounded-xl px-4 py-3 text-white focus:border-indigo-500 outline-none transition-all" 
          />
        </div>

        <button 
          id="send-link" 
          type="button"
          class="w-full py-4 bg-white text-black font-black uppercase text-xs tracking-[0.2em] rounded-xl hover:bg-indigo-500 hover:text-white transition-all shadow-xl active:scale-95"
        >
          Send Magic Link
        </button>
      </div>

      <p id="msg" class="hidden mt-6 text-center text-emerald-400 text-[10px] font-bold uppercase tracking-widest animate-pulse">
        Check your inbox! 📧
      </p>
    </div>
  </main>
</Layout>

<script>
  // Astro preporučuje da skripta bude unutar layouta ili u zasebnom bloku
  // Koristimo "is:inline" ako imamo problema, ali standardni script je bolji
  
  const setupLogin = () => {
    const btn = document.getElementById('send-link');
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const msg = document.getElementById('msg');

    btn?.addEventListener('click', async () => {
      const email = emailInput?.value;
      
      if (!email || !email.includes('@')) {
        alert('Please enter a valid email address.');
        return;
      }
      
      // Onemogući dugme dok traje slanje
      btn.textContent = 'SENDING...';
      (btn as HTMLButtonElement).disabled = true;

      try {
        const res = await fetch('/api/auth/magic-link', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        if (res.ok) {
          msg?.classList.remove('hidden');
          btn.textContent = 'LINK SENT';
        } else {
          const errorData = await res.json().catch(() => ({}));
          alert(`Error: ${errorData.message || 'Something went wrong'}`);
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = 'SEND MAGIC LINK';
        }
      } catch (err) {
        console.error(err);
        alert('Network error. Check your connection.');
        (btn as HTMLButtonElement).disabled = false;
        btn.textContent = 'SEND MAGIC LINK';
      }
    });
  };

  // Pokreni skriptu tek kad se DOM učita
  setupLogin();
</script>
