---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Payment Successful | Tools Nestt">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="max-w-md w-full bg-slate-900/40 border border-emerald-500/30 p-12 rounded-[3rem] text-center backdrop-blur-xl relative">
      <!-- Glow efekat za uspeh -->
      <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-40 h-40 bg-emerald-500/20 blur-[60px] rounded-full -z-10"></div>
      
      <div class="w-20 h-20 bg-emerald-500/10 border border-emerald-500/20 rounded-full flex items-center justify-center mx-auto mb-8">
        <span class="text-3xl">✅</span>
      </div>

      <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter mb-4">Payment Confirmed</h1>
      <p class="text-slate-400 text-sm italic mb-10 leading-relaxed">
        Your account has been upgraded to <span class="text-white font-bold">Business Pro</span>. The US-West Edge infrastructure is now fully unlocked for your projects.
      </p>

      <a href="/dashboard" class="block w-full py-5 bg-white text-black font-black uppercase text-xs tracking-[0.2em] rounded-2xl hover:bg-emerald-500 hover:text-white transition-all shadow-xl shadow-white/5 active:scale-95">
        Go to Dashboard
      </a>

      <p class="mt-8 text-[10px] text-slate-600 uppercase font-bold tracking-widest italic">
        Transaction processed by Paddle
      </p>
    </div>
  </main>
</Layout>
